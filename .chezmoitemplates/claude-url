{{- if (or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin")) -}}
{{- $version := includeTemplate "claude-version" . | trim -}}
{{- $arch := .chezmoi.arch -}}
{{- if eq $arch "amd64" -}}
{{- $arch = "x64" -}}
{{- end -}}
{{- printf "https://downloads.claude.ai/claude-code-releases/%s/%s-%s/claude" $version .chezmoi.os $arch -}}
{{- else -}}
{{- "" -}}
{{- end -}}
