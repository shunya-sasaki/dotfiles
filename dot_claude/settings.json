{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(biome format *)",
      "Bash(biome lint *)",
      "Bash(dprint check *)",
      "Bash(dprint fmt*)",
      "Bash(echo $TMUX_PANE)",
      "Bash(echo $WEZTERM_PANE)",
      "Bash(echo $ZELLIJ_PANE_ID)",
      "Bash(gh issue*)",
      "Bash(gh label*)",
      "Bash(gh pr*)",
      "Bash(gh repo*)",
      "Bash(git --no-pager diff*)",
      "Bash(git branch*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git push*)",
      "Bash(git worktree*)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(tmux*)",
      "Bash(wezterm*)",
      "Bash(uv run pytest)",
      "Bash(uv run ruff *)",
      "Bash(uv run ty *)",
      "Bash(uv sync)",
      "Bash(wezterm cli*)",
      "Bash(zellij*)",
      "Edit(**/AppData/Local/Temp/**)",
      "Edit(/tmp/**)",
      "Edit(doc/**)",
      "Edit(docs/**)",
      "Edit(src/**)",
      "Glob(doc/**)",
      "Glob(docs/**)",
      "Glob(src/**)",
      "Read(**/AppData/Local/Temp/**)",
      "Read(/tmp/**)",
      "Read(doc/**)",
      "Read(docs/**)",
      "Read(src/**)",
      "Read(~/.zshrc)",
      "Skill",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:github.com)",
      "Write(**/AppData/Local/Temp/**)",
      "Write(/tmp/**)",
      "Write(doc/**)",
      "Write(docs/**)",
      "Write(src/**)"
    ],
    "ask": ["Bash(curl *)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Glob(secrets/**)"
    ]
  }
}
