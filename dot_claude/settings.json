{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(biome format *)",
      "Bash(biome lint *)",
      "Bash(dprint check *)",
      "Bash(dprint fmt*)",
      "Bash(echo $TMUX_PANE)",
      "Bash(echo $WEZTERM_PANE)",
      "Bash(echo $ZELLIJ_PANE_ID)",
      "Bash(gh *issue*)",
      "Bash(gh *label*)",
      "Bash(gh *pr*)",
      "Bash(gh *repo*)",
      "Bash(tea *issue*)",
      "Bash(tea *label*)",
      "Bash(tea *pr*)",
      "Bash(tea *repo*)",
      "Bash(git *branch*)",
      "Bash(git *commit*)",
      "Bash(git *diff*)",
      "Bash(git *log*)",
      "Bash(git *push*)",
      "Bash(git *status*)",
      "Bash(git *worktree*)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(rm */tmp/**)",
      "Bash(rm */AppData/Local/Temp/**)",
      "Bash(tmux *)",
      "Bash(uv run pytest)",
      "Bash(uv run ruff *)",
      "Bash(uv run ty *)",
      "Bash(uv sync)",
      "Bash(wezterm *)",
      "Bash(zellij *)",
      "Edit(**/AppData/Local/Temp/**)",
      "Edit(/tmp/**)",
      "Edit(doc/**)",
      "Edit(docs/**)",
      "Edit(src/**)",
      "Glob(doc/**)",
      "Glob(docs/**)",
      "Glob(src/**)",
      "Read(**/AppData/Local/Temp/**)",
      "Read(/tmp/**)",
      "Read(doc/**)",
      "Read(docs/**)",
      "Read(src/**)",
      "Read(~/.zshrc)",
      "Skill",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:github.com)",
      "Write(**/AppData/Local/Temp/**)",
      "Write(/tmp/**)",
      "Write(doc/**)",
      "Write(docs/**)",
      "Write(src/**)"
    ],
    "ask": ["Bash(curl *)"],
    "deny": [
      "Bash(cat *.crt*)",
      "Bash(cat *.env*)",
      "Bash(cat *.key*)",
      "Bash(cat *.pem*)",
      "Bash(cat *secret*)",
      "Bash(head *.crt*)",
      "Bash(head *.env*)",
      "Bash(head *.key*)",
      "Bash(head *.pem*)",
      "Bash(head *secret*)",
      "Bash(tail *.crt*)",
      "Bash(tail *.env*)",
      "Bash(tail *.key*)",
      "Bash(tail *.pem*)",
      "Bash(tail *secret*)",
      "Glob(**secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.aws/**)",
      "Read(**/.env*)",
      "Read(**/.npmrc)",
      "Read(**/.ssh/**)",
      "Read(**/secrets/**)"
    ]
  }
}
