#!/bin/bash

session=$1
pane_id=$2
message=$3
shift 3

extra_args=()
for arg in "$@"; do
    case "$arg" in
        --require_response)
            extra_args+=(--require_response)
            ;;
    esac
done

export PYTHONPATH=$HOME/.bin

if command -v uv &> /dev/null; then
    uv run "${HOME}/.bin/agent/main.py" \
        send --session "$session" --pane_id "$pane_id" --message "$message" "${extra_args[@]}"
elif command -v python3 &> /dev/null; then
    python3 "${HOME}/.bin/agent/main.py" \
        send --session "$session" --pane_id "$pane_id" --message "$message" "${extra_args[@]}"
else
    echo "Error: neither uv nor python3 is available." >&2
    exit 2
fi

