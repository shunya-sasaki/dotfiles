  source '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
fi
export PATH="$HOME/.nix-profile/bin:$PATH"

# ~/.profile.d ================================================================
# Source every *.sh under ~/.profile.d (works in both bash and zsh)
function source_profile_d() {
    local dir="$HOME/.profile.d"
    [ -d "$dir" ] || return
    setopt localoptions nullglob 2>/dev/null
    shopt -s nullglob 2>/dev/null
    for f in "$dir"/*.sh; do
        [ "${f##*/}" = "shell.sh" ] && continue
        [ -r "$f" ] && source "$f"
    done
}
source_profile_d


