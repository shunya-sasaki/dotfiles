{{- $profile := dig "profile" "home" . -}}
{{- $baseConfig := include "private_dot_config/zed/settings/base.json" | mustFromJson -}}
{{- $homeConfig := include "private_dot_config/zed/settings/home.json" | mustFromJson -}}
{{- $workConfig := include "private_dot_config/zed/settings/work.json" | mustFromJson -}}

{{- /* 1. Initialize the variable outside the block */ -}}
{{- $mergedConfig := dict -}}

{{- if eq $profile "home" -}}
  {{- /* 2. Use '=' to REASSIGN the variable, not ':=' */ -}}
  {{- $mergedConfig = mergeOverwrite (dict) $baseConfig $homeConfig -}}
{{- else -}}
  {{- $mergedConfig = mergeOverwrite (dict) $baseConfig $workConfig -}}
{{- end -}}

{{- $mergedConfig | toPrettyJson -}}
