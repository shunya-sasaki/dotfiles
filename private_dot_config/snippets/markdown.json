{
  "Tree Leaf": {
    "prefix": "tree-leaf",
    "description": "Tree leaf glyph for directory structures",
    "body": ["└── ${1:name}"]
  },
  "Tree Pipe": {
    "prefix": "tree-pipe",
    "description": "Vertical pipe for tree indentation",
    "body": ["│   "]
  },
  "Tree Stem": {
    "prefix": "tree-stem",
    "description": "Tree stem glyph for branching",
    "body": ["├── ${1:name}"]
  },
  "Shields.io Static Badge": {
    "prefix": "md-shields-static",
    "description": [
      "Insert a static badge from Shields.io.",
      "badgeName: The name of the badge and right side text.",
      "rightBgColor: The background color of the right side of the badge.",
      "logo: The logo to use for the badge.",
      "leftBgColor: The background color of the left side of the badge.",
      "logoColor: The color of the logo."
    ],
    "body": [
      "![${1:badgeName}](https://img.shields.io/badge/${1:badgeName}-${2:gray}?logo=${1:badgeName}&labelColor=${3:gray}&logoColor=${4:white})"
    ]
  },
  "Shields.io GitHub License": {
    "prefix": "md-shields-license",
    "description": [
      "Insert a license badge from Shields.io.",
      "user: The GitHub username.",
      "repo: The repository name."
    ],
    "body": [
      "![${1:badgeName}](https://img.shields.io/github/license/${2:user}/${3:repo})"
    ]
  },
