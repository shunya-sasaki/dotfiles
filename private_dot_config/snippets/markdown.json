  "Mermaid Flowchart Block": {
    "prefix": "mmd-flowchart",
    "body": ["```mermaid", "flowchart TD", "```"]
  },
  "Mermaid.js Flowchart": {
    "prefix": "mmd-flowchart-config",
    "description": "Mermaid.js Flowchart",
    "body": [
      "---",
      "config:",
      "    theme: base",
      "    themeVariables:",
      "        fontSize: 1rem;",
      "        fontFamily: \"Helvetica Neue, Calibri, Hiragino Kaku Gothic ProN, Yu Gothic\"",
      "        background: \"#ffffff\"",
      "        primaryColor: \"#82a0aa\"",
      "        primaryTextColor: \"#ffffff\"",
      "        secondaryColor: \"#3c5d69\"",
      "        secondaryTextColor: \"#ffffff\"",
      "        tertiaryColor: \"#b4c6cc\"",
      "        tertiaryTextColor: \"#000000\"",
      "        noteBkgColor: \"#b4c6cc\"",
      "        noteTextColor: \"#000000\"",
      "        lineColor: \"#2b72b3\"",
      "        textColor: \"#000000\"",
      "    flowchart:",
      "        padding: 10",
      "        diagramPadding: 10 ",
      "        nodeSpacing: 25",
      "        rankSpacing: 25",
      "        curve: basis",
      "---",
      "```"
    ]
  },
  "Flowchart Edge Class Def": {
    "prefix": "mmd-flowchart-edge-class-def",
    "description": "Flowchart Edge Class Definition",
    "body": "classDef ${1:className} stroke:${2:color},stroke-dasharray: 9,5,stroke-dashoffset: 900,animation: dash 25s linear infinite"
  },
