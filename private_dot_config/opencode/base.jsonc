{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "*": "ask",
      "**/tmp/**": "allow",
      "**\\APP_DATA\\Local\\Temp\\**": "allow",
      "~/.config/**": "allow",
      "~/.claude/**": "allow",
      "~/.codex/**": "allow",
      "~/.agents/**": "allow"
    },
    "*": "ask",
    "bash": {
      "*": "ask",
      "echo *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "biome format *": "allow",
      "biome lint *": "allow",
      "dprint check *": "allow",
      "dprint fmt*": "allow",
      "gh *issue*": "allow",
      "gh *label*": "allow",
      "gh *pr*": "allow",
      "gh *repo*": "allow",
      "tea *issue*": "allow",
      "tea *label*": "allow",
      "tea *pr*": "allow",
      "tea *repo*": "allow",
      "git *branch*": "allow",
      "git *commit*": "allow",
      "git *diff*": "allow",
      "git *log*": "allow",
      "git *push*": "allow",
      "git *status*": "allow",
      "git *worktree*": "allow",
      "npm run lint": "allow",
      "npm run test *": "allow",
      "rm */tmp/**": "allow",
      "rm */AppData/Local/Temp/**": "allow",
      "tmux *": "allow",
      "wezterm *": "allow",
      "zellij *": "allow",
      "uv run pytest": "allow",
      "uv run ruff *": "allow",
      "uv run ty *": "allow",
      "uv sync": "allow",
      "curl *": "ask",
      "cat *.crt*": "deny",
      "cat *.env*": "deny",
      "cat *.key*": "deny",
      "cat *.pem*": "deny",
      "cat *secret*": "deny",
      "head *.crt*": "deny",
      "head *.env*": "deny",
      "head *.key*": "deny",
      "head *.pem*": "deny",
      "head *secret*": "deny",
      "tail *.crt*": "deny",
      "tail *.env*": "deny",
      "tail *.key*": "deny",
      "tail *.pem*": "deny",
      "tail *secret*": "deny"
    },
    "edit": {
      "*": "ask",
      "doc/**": "allow",
      "docs/**": "allow",
      "src/**": "allow",
      "/tmp/**": "allow",
      "**/AppData/Local/Temp/**": "allow"
    },
    "read": {
      "*": "allow",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/.aws/**": "deny",
      "**/.env*": "deny",
      "**/.npmrc": "deny",
      "**/.ssh/**": "deny",
      "**/secrets/**": "deny"
    },
    "grep": "ask",
    "glob": {
      "*": "allow",
      "**secrets/**": "deny"
    },
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "allow",
    "question": "allow"
  }
}
