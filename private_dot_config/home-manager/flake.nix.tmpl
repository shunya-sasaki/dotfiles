{
  description = "Home Manager configuration";

  nixConfig = {
    extra-substituters = [ "https://nix-community.cachix.org" ];
    extra-trusted-public-keys = ["nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs="];
  };

  inputs = {
    # Specify the source of Home Manager and Nixpkgs.
    nixpkgs.url = "github:nixos/nixpkgs/nixpkgs-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs =
    { nixpkgs, home-manager, ... }:
    let
      username = "{{ .chezmoi.username }}";
      os = "{{ .chezmoi.os }}";
      arch = "{{ .chezmoi.arch }}";
      archMap = {
          "arm64" = "aarch64";
          "amd64" = "amd64";
        };
      archName = archMap.${arch} or arch;
      system = "${archName}-${os}";
      # pkgs = nixpkgs.legacyPackages.${system};
      # HACK: Since direnv's tests fail on darwin, we need to disable them in the overlay.
      pkgs = import nixpkgs {
        inherit system;
        overlays = [
          (final: prev: {
            direnv = prev.direnv.overrideAttrs (old: {
              doCheck = false;
              doInstallCheck = false;
            });
          })
          (final: prev: {
            claude-code = prev.stdenv.mkDerivation rec {
              pname = "claude";
              version = "{{ includeTemplate `claude-version` . }}";
              src = prev.fetchurl {
                url = "https://downloads.claude.ai/claude-code-releases/${version}/${os}-${arch}/claude";
                hash = "{{ includeTemplate `claude-hash` . }}";
              };
              dontUnpack = true;
              nativeBuildInputs = [ prev.makeWrapper ];
              installPhase = ''
                install -Dm755 $src $out/bin/claude
              '';
              postFixup = ''
                wrapProgram $out/bin/claude \
                  --set DISABLE_AUTOUPDATER 1 \
                  --set DISABLE_INSTALLATION_CHECKS 1 \
              '';
            };
          })
          (final: prev: {
            copilot = prev.stdenv.mkDerivation {
              pname = "copilot";
              version = "{{ includeTemplate `copilot-version` . }}";
              src = prev.fetchurl {
                url = "{{ includeTemplate `copilot-url` . }}";
                hash = "{{ includeTemplate `copilot-hash` . }}";
              };
              sourceRoot = ".";
              nativeBuildInputs = [ prev.makeWrapper ];
              installPhase = ''
                install -Dm755 copilot $out/bin/copilot
              '';
            };
          })
        ];
      };
    in
    {
      homeConfigurations."${username}" = home-manager.lib.homeManagerConfiguration {
        inherit pkgs;

        # Specify your home configuration modules here, for example,
        # the path to your home.nix.
        modules = [ ./home.nix ];

      };
    };
}
