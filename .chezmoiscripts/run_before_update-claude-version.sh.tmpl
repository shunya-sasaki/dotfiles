{{- if (or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin")) -}}
{{- $profile := includeTemplate "profile" . | trim -}}

{{- $cachedClaudeVersion := index . "claudeVersion" | default "" -}}
{{- $cachedClaudeHash := index . "claudeHash" | default "" -}}

{{- $cachedCopilotVersion := index . "copilotVersion" | default "" -}}
{{- $cachedCopilotHash := index . "copilotHash" | default "" -}}

{{- $cachedGeminiVersion := index . "geminiVersion" | default "" -}}
{{- $cachedGeminiHash := index . "geminiHash" | default "" -}}

{{- $cachedZedVersion := index . "zedVersion" | default "" -}}
{{- $cachedZedHash := index . "zedHash" | default "" -}}

{{- $cachedMiseVersion := index . "miseVersion" | default "" -}}
{{- $cachedMiseHash := index . "miseHash" | default "" -}}

#!/bin/sh
claude_version="{{- includeTemplate "claude-version" . -}}"
if [ "$claude_version" = "{{- $cachedClaudeVersion -}}" ] \
    && [ -n "{{- $cachedClaudeHash -}}" ]; then
    echo "Claude Code is up to date, using cached hash."
    claude_hash="{{- $cachedClaudeHash -}}"
else
    claude_hash="{{- includeTemplate "claude-hash" . -}}"
fi

copilot_version="{{- includeTemplate "copilot-version" . -}}"
if [ "$copilot_version" = "{{- $cachedCopilotVersion -}}" ] \
    && [ -n "{{- $cachedCopilotHash -}}" ]; then
    echo "GitHub Copilot is up to date, using cached hash."
    copilot_hash="{{- $cachedCopilotHash -}}"
else
    copilot_hash="{{- includeTemplate "copilot-hash" . -}}"
fi

gemini_version="{{- includeTemplate "gemini-version" . -}}"
if [ "$gemini_version" = "{{- $cachedGeminiVersion -}}" ] \
    && [ -n "{{- $cachedGeminiHash -}}" ]; then
    echo "Gemini is up to date, using cached hash."
    gemini_hash="{{- $cachedGeminiHash -}}"
else
    gemini_hash="{{- includeTemplate "gemini-hash" . -}}"
fi

zed_version="{{- includeTemplate "zed-version" . -}}"
if [ "$zed_version" = "{{- $cachedZedVersion -}}" ] \
    && [ -n "{{- $cachedZedHash -}}" ]; then
    echo "Zed is up to date, using cached hash."
    zed_hash="{{- $cachedZedHash -}}"
else
    zed_hash="{{- includeTemplate "zed-hash" . -}}"
fi

mise_version="{{- includeTemplate "mise-version" . -}}"
if [ "$mise_version" = "{{- $cachedMiseVersion -}}" ] \
    && [ -n "{{- $cachedMiseHash -}}" ]; then
    echo "mise is up to date, using cached hash."
    mise_hash="{{- $cachedMiseHash -}}"
else
    mise_hash="{{- includeTemplate "mise-hash" . -}}"
fi

if [ ! -d ~/.config/chezmoi ]; then
    mkdir -p ~/.config/chezmoi
fi

cat <<EOF > ~/.config/chezmoi/chezmoi.toml
[edit]
command = "nvim"
[data]
profile = "{{ $profile }}"
claudeVersion = "$claude_version"
claudeHash = "$claude_hash"
copilotVersion = "$copilot_version"
copilotHash = "$copilot_hash"
geminiVersion = "$gemini_version"
geminiHash = "$gemini_hash"
zedVersion = "$zed_version"
zedHash = "$zed_hash"
miseVersion = "$mise_version"
miseHash = "$mise_hash"
EOF
{{- end -}}

